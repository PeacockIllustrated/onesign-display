# Supabase — get these from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Media CDN — Cloudflare Worker proxy (optional, falls back to Supabase signed URLs)
# Set this to eliminate Supabase egress costs at scale.
MEDIA_CDN_URL=https://onesign-media-proxy.your-account.workers.dev
